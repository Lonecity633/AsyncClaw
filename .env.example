# LLM provider settings
# Supported providers: openai, deepseek, siliconflow, xiaomi, anthropic
LLM_PROVIDER=openai

# Generic settings work for any provider.
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini

# Optional: override the provider's default OpenAI-compatible endpoint.
# LLM_BASE_URL=https://api.openai.com/v1

# Provider-specific settings are also supported and take precedence.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-v4-flash
#
# SILICONFLOW_API_KEY=your-siliconflow-api-key
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
#
# MIMO_API_KEY=your-xiaomi-mimo-api-key
# MIMO_MODEL=mimo-v2.5-pro

# Judge LLM settings, used only by evals/run_eval.py --judge.
# Keep this separate from the agent-under-test LLM settings.
JUDGE_LLM_PROVIDER=openai
JUDGE_LLM_API_KEY=your-judge-api-key
JUDGE_LLM_MODEL=gpt-4o-mini
# JUDGE_LLM_BASE_URL=https://api.openai.com/v1

# Agent runtime settings
AGENT_MAX_STEPS=8

# Tavily web search/fetch tools
# TAVILY_API_KEY=your-tavily-api-key

# Optional: enable third-party MCP tool providers.
# MCP_CONFIG=./mcp.servers.json
# GitHub read-only PR/code review example:
# MCP_CONFIG=./mcp.servers.github.example.json
# GITHUB_MCP_TOKEN=your-github-token
