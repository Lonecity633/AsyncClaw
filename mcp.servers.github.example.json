{
  "servers": [
    {
      "name": "github",
      "transport": "streamable-http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_TOKEN}",
        "X-MCP-Toolsets": "repos,pull_requests",
        "X-MCP-Readonly": "true",
        "X-MCP-Lockdown": "false"
      },
      "timeout_seconds": 15,
      "enabled": true,
      "allow_cron": false
    }
  ]
}
